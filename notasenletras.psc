Algoritmo letras
	escribir "*** Notas en letras***"
	Definir letra Como Caracter
	Escribir Sin Saltar "ingrese una letra: "
	leer letra
	Segun letra Hacer
		"A":
			escribir "excelente"
		"B":
			Escribir "bueno"
		"C":
			Escribir "regular"
		"D":
			Escribir "deficiente"
		"F":
			Escribir "reprobado"
		De Otro Modo:
			Escribir "ingrese una nota valida"
	Fin Segun
	
FinAlgoritmo

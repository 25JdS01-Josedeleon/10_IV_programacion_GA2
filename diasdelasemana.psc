Algoritmo diasdelasemana
	Definir dia Como Entero
	escribir sin saltar "dame un numero del 1 al 7: "
	leer dia
	Segun dia Hacer
		1:
			Escribir "lunes"
		2:
			escribir "martes"
		3:
			escribir "miercoles"
		4:
			Escribir "jueves"
		5:
			Escribir "viernes"
		6:
			Escribir "sabado"
		7:
			Escribir "domingo"
		De Otro Modo:
			Escribir "digite un valor entre el 1 y el 7"
			
	Fin Segun
FinAlgoritmo
